{
  "servers": [
    {
      "id": "exa",
      "name": "Exa Search",
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa",
      "autoConnect": true,
      "tools": ["web_search_exa", "get_code_context_exa"]
    },
    {
      "id": "exa-full",
      "name": "Exa Search (All Tools)",
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check"
    },
    {
      "id": "exa-local",
      "name": "Exa Search (Local)",
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "exa-mcp-server", "tools=web_search_exa,get_code_context_exa"],
      "env": {
        "EXA_API_KEY": "your-api-key-here"
      }
    },
    {
      "id": "filesystem",
      "name": "Filesystem Server",
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/directory"]
    }
  ]
}
